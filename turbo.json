{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "env": [
                "VITE_API_BASE_URL",
                "VITE_MICROSOFT_TENANT_ID",
                "VITE_MAREX_WS_URL"
            ],
            "outputs": [
                "dist/**",
                "build/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}